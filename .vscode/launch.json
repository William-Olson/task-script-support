  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Tests",
      "request": "launch",
      "runtimeArgs": ["test"],
      "runtimeExecutable": "npm",
      "skipFiles": ["<node_internals>/**"],
      "type": "node"
    },

    {
      "type": "node",
      "request": "launch",
      "name": "Run example 4",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/examples/example-4/index.js",
      "preLaunchTask": "tsc: build - tsconfig.json",
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "args": ["-t"]
    }
  ]
}
