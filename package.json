{
  "name": "task-script-support",
  "version": "2.2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "type": "commonjs",
  "scripts": {
    "start": "jiti src/index.ts",
    "dev": "npm run build && node dist/src/index.js",
    "clean": "rm -rf ./dist",
    "lint": "eslint --config eslint.config.ts",
    "format": "prettier --write ./",
    "format-check": "prettier --check .",
    "hooks-one-time-setup": "npx simple-git-hooks",
    "prettier-watch": "onchange \"**/*\" -- prettier --write --ignore-unknown {{changed}}",
    "build": "rm -rf ./dist && npx tsc",
    "test": "vitest run",
    "test-watch": "vitest"
  },
  "keywords": [
    "tasks",
    "script"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/William-Olson/task-script-support.git"
  },
  "author": "willko747@gmail.com",
  "license": "MIT",
  "description": "Opinionated library for writing task scripts",
  "simple-git-hooks": {
    "pre-commit": "npx pretty-quick --staged && npm run lint"
  },
  "dependencies": {
    "immutable": "^5.1.4",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "jiti": "^2.6.1",
    "onchange": "^7.1.0",
    "prettier": "^3.7.1",
    "pretty-quick": "^4.2.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.15"
  }
}
