{
  "name": "tss-ex1",
  "version": "1.0.0",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "jiti src/index.ts",
    "dev": "npm run build && node dist/src/index.js",
    "clean": "rm -rf ./dist",
    "lint": "eslint --config eslint.config.ts",
    "format": "prettier --write ./",
    "format-check": "prettier --check .",
    "hooks-one-time-setup": "npx simple-git-hooks",
    "prettier-watch": "onchange \"**/*\" -- prettier --write --ignore-unknown {{changed}}",
    "build": "rm -rf ./dist && npx tsc && node dist/src/index.js -v",
    "test": "vitest run",
    "test-watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "simple-git-hooks": {
    "pre-commit": "npx pretty-quick --staged && npm run lint"
  },
  "dependencies": {
    "task-script-support": "../../dist",
    "chalk": "^4.1.2",
    "dotenv": "^17.2.3",
    "figlet": "^1.9.4",
    "immutable": "^5.1.4",
    "pino": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/yargs": "^17.0.35",
    "eslint": "^9.39.1",
    "jiti": "^2.6.1",
    "onchange": "^7.1.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.1",
    "pretty-quick": "^4.2.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.15"
  }
}
